{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@marvicqui/shared-auth": ["packages/shared-auth/src/index.ts"],
      "@marvicqui/shared-db": ["packages/shared-db/src/index.ts"],
      "@marvicqui/shared-ui": ["packages/shared-ui/src/index.ts"],
      "@marvicqui/shared-agents": ["packages/shared-agents/src/index.ts"],
      "@marvicqui/shared-notifications": ["packages/shared-notifications/src/index.ts"],
      "@marvicqui/cfdi": ["packages/modules/cfdi/src/index.ts"],
      "@marvicqui/laboral": ["packages/modules/laboral/src/index.ts"],
      "@marvicqui/contratos": ["packages/modules/contratos/src/index.ts"]
    }
  }
}
